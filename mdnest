#!/bin/bash
set -e

MDNEST_CLI_VERSION="2.0.1"
CONFIG_DIR="${HOME}/.config/mdnest"
CONFIG_FILE="${CONFIG_DIR}/config"

# ─── Config helpers ──────────────────────────────────────────────────────────

load_config() {
  if [ -f "$CONFIG_FILE" ]; then
    MDNEST_URL=$(grep '^url=' "$CONFIG_FILE" 2>/dev/null | cut -d= -f2-)
    MDNEST_TOKEN=$(grep '^token=' "$CONFIG_FILE" 2>/dev/null | cut -d= -f2-)
  fi
}

require_config() {
  load_config
  if [ -z "$MDNEST_URL" ] || [ -z "$MDNEST_TOKEN" ]; then
    echo "Not logged in. Run: mdnest login <url> <token>"
    exit 1
  fi
}

api() {
  local method="$1" path="$2" body="$3"
  local args=(-s -w "\n%{http_code}" -H "Authorization: Bearer $MDNEST_TOKEN")
  [ -n "$body" ] && args+=(-d "$body")
  local response
  response=$(curl "${args[@]}" -X "$method" "${MDNEST_URL}/api${path}")
  local http_code="${response##*$'\n'}"
  local body="${response%$'\n'*}"

  if [ "$http_code" -ge 400 ] 2>/dev/null; then
    echo "Error ($http_code): $body" >&2
    return 1
  fi
  echo "$body"
}

urlencode() {
  python3 -c "import urllib.parse, sys; print(urllib.parse.quote(sys.argv[1]))" "$1"
}

# ─── Note commands ───────────────────────────────────────────────────────────

note_cmd() {
  local subcmd="${1:-help}"
  shift 2>/dev/null || true

  if [ "$subcmd" = "help" ] || [ "$subcmd" = "--help" ] || [ "$subcmd" = "-h" ]; then
    subcmd="help_text"
  else
    require_config
  fi

  case "$subcmd" in
    list)
      local ns="$1"
      if [ -z "$ns" ]; then
        api GET "/namespaces"
      else
        api GET "/tree?ns=$(urlencode "$ns")"
      fi
      ;;
    read)
      local ns="$1" path="$2"
      [ -z "$ns" ] || [ -z "$path" ] && { echo "Usage: mdnest note read <namespace> <path>" >&2; exit 1; }
      api GET "/note?ns=$(urlencode "$ns")&path=$(urlencode "$path")"
      ;;
    write)
      local ns="$1" path="$2" content="$3"
      [ -z "$ns" ] || [ -z "$path" ] && { echo "Usage: mdnest note write <namespace> <path> <content>" >&2; exit 1; }
      [ "$content" = "-" ] && content=$(cat)
      [ -z "$content" ] && content=$(cat)
      api PUT "/note?ns=$(urlencode "$ns")&path=$(urlencode "$path")" "$content"
      ;;
    create)
      local ns="$1" path="$2" content="${3:-}"
      [ -z "$ns" ] || [ -z "$path" ] && { echo "Usage: mdnest note create <namespace> <path> [content]" >&2; exit 1; }
      api POST "/note?ns=$(urlencode "$ns")&path=$(urlencode "$path")" "$content"
      ;;
    append)
      local ns="$1" path="$2" content="$3"
      [ -z "$ns" ] || [ -z "$path" ] && { echo "Usage: mdnest note append <namespace> <path> <content>" >&2; exit 1; }
      [ "$content" = "-" ] && content=$(cat)
      [ -z "$content" ] && content=$(cat)
      api PATCH "/note?ns=$(urlencode "$ns")&path=$(urlencode "$path")&position=bottom" "$content"
      ;;
    prepend)
      local ns="$1" path="$2" content="$3"
      [ -z "$ns" ] || [ -z "$path" ] && { echo "Usage: mdnest note prepend <namespace> <path> <content>" >&2; exit 1; }
      [ "$content" = "-" ] && content=$(cat)
      [ -z "$content" ] && content=$(cat)
      api PATCH "/note?ns=$(urlencode "$ns")&path=$(urlencode "$path")&position=top" "$content"
      ;;
    delete)
      local ns="$1" path="$2"
      [ -z "$ns" ] || [ -z "$path" ] && { echo "Usage: mdnest note delete <namespace> <path>" >&2; exit 1; }
      api DELETE "/note?ns=$(urlencode "$ns")&path=$(urlencode "$path")"
      ;;
    move)
      local ns="$1" from="$2" to="$3"
      [ -z "$ns" ] || [ -z "$from" ] || [ -z "$to" ] && { echo "Usage: mdnest note move <namespace> <from> <to>" >&2; exit 1; }
      api POST "/move?ns=$(urlencode "$ns")&from=$(urlencode "$from")&to=$(urlencode "$to")"
      ;;
    search)
      local ns="$1" query="$2"
      [ -z "$ns" ] || [ -z "$query" ] && { echo "Usage: mdnest note search <namespace> <query>" >&2; exit 1; }
      api GET "/search?ns=$(urlencode "$ns")&q=$(urlencode "$query")"
      ;;
    help_text)
      cat <<'HELP'
Usage: mdnest note <command> [args]

Commands:
  list    [namespace]                     List namespaces, or files in a namespace
  read    <namespace> <path>              Read a note
  write   <namespace> <path> <content>    Overwrite a note (use - for stdin)
  create  <namespace> <path> [content]    Create a new note
  append  <namespace> <path> <content>    Append text to a note (use - for stdin)
  prepend <namespace> <path> <content>    Prepend text to a note (use - for stdin)
  delete  <namespace> <path>              Delete a note or folder
  move    <namespace> <from> <to>         Move/rename a note or folder
  search  <namespace> <query>             Search notes

Examples:
  mdnest note list
  mdnest note list my_notes
  mdnest note read my_notes ideas.md
  mdnest note append my_notes log.md "## $(date) - Meeting notes"
  echo "new content" | mdnest note write my_notes draft.md -
HELP
      ;;
    *)
      echo "Unknown note command: $subcmd" >&2
      echo "Run 'mdnest note help' for usage" >&2
      exit 1
      ;;
  esac
}

# ─── Main dispatch ───────────────────────────────────────────────────────────

CMD="${1:-help}"
shift 2>/dev/null || true

case "$CMD" in
  login)
    url="$1"
    tok="$2"
    if [ -z "$url" ] || [ -z "$tok" ]; then
      echo "Usage: mdnest login <url> <token>"
      echo "  url:   Your mdnest server URL (e.g. https://myserver:3236)"
      echo "  token: API token from Settings > API Tokens in the web UI"
      exit 1
    fi
    url="${url%/}"
    mkdir -p "$CONFIG_DIR"
    cat > "$CONFIG_FILE" <<EOF
url=${url}
token=${tok}
EOF
    chmod 600 "$CONFIG_FILE"
    if MDNEST_URL="$url" MDNEST_TOKEN="$tok" api GET "/namespaces" > /dev/null 2>&1; then
      echo "Logged in to $url"
      # Check version compatibility
      SERVER_VER=$(curl -s "${url}/api/config" 2>/dev/null | grep -o '"version":"[^"]*"' | cut -d'"' -f4)
      if [ -n "$SERVER_VER" ]; then
        CLI_MAJOR="${MDNEST_CLI_VERSION%%.*}"
        SRV_MAJOR="${SERVER_VER%%.*}"
        if [ "$CLI_MAJOR" != "$SRV_MAJOR" ]; then
          echo "Warning: CLI v${MDNEST_CLI_VERSION} may not be compatible with server v${SERVER_VER}"
          echo "Update CLI: curl -fsSL https://raw.githubusercontent.com/mahsanamin/mdnest/v2.0/install-cli.sh | bash"
        fi
      fi
    else
      echo "Warning: could not reach $url — credentials saved, will retry on next command"
    fi
    ;;
  logout)
    rm -f "$CONFIG_FILE"
    echo "Logged out"
    ;;
  whoami)
    load_config
    if [ -n "$MDNEST_URL" ]; then
      echo "CLI:    v${MDNEST_CLI_VERSION}"
      # Fetch server version
      SERVER_INFO=$(curl -s "${MDNEST_URL}/api/config" 2>/dev/null || echo "{}")
      SERVER_VER=$(echo "$SERVER_INFO" | grep -o '"version":"[^"]*"' | cut -d'"' -f4)
      [ -n "$SERVER_VER" ] && echo "Server: v${SERVER_VER} (${MDNEST_URL})" || echo "Server: $MDNEST_URL"
      echo "Token:  ${MDNEST_TOKEN:0:12}..."
    else
      echo "Not logged in. Run: mdnest login <url> <token>"
    fi
    ;;
  version|--version|-v)
    echo "mdnest CLI v${MDNEST_CLI_VERSION}"
    ;;
  note)
    note_cmd "$@"
    ;;
  docs)
    REAL_PATH="$(readlink -f "$0" 2>/dev/null || python3 -c "import os,sys; print(os.path.realpath(sys.argv[1]))" "$0")"
    DOCS_DIR="$(dirname "$REAL_PATH")/docs"
    if [ -f "$DOCS_DIR/cli.md" ]; then
      cat "$DOCS_DIR/cli.md"
    else
      echo "Docs not found. Expected at: $DOCS_DIR/cli.md"
      exit 1
    fi
    ;;
  help|--help|-h)
    cat <<HELP
mdnest CLI v${MDNEST_CLI_VERSION} — notes on your terms

Usage: mdnest <command>

Commands:
  login   <url> <token>     Authenticate with an mdnest server
  logout                    Remove saved credentials
  whoami                    Show CLI version, server version, and connection info
  version                   Show CLI version
  note    <subcommand>      Read, write, append, search notes (run 'mdnest note help')
  docs                      Print the full CLI reference

Examples:
  mdnest login https://myserver:3236 tok_abc123
  mdnest note list
  mdnest note read my_notes ideas.md
  mdnest note append my_notes log.md "Meeting notes here"
  echo "piped content" | mdnest note write my_notes draft.md -
HELP
    ;;
  *)
    echo "Unknown command: $CMD"
    echo "Run 'mdnest help' for usage"
    exit 1
    ;;
esac
