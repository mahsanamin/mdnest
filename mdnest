#!/bin/bash
set -e

MDNEST_CLI_VERSION="3.3.0"
CONFIG_DIR="${HOME}/.config/mdnest"
SERVERS_DIR="${CONFIG_DIR}/servers"
DEFAULT_FILE="${CONFIG_DIR}/default"

# Legacy single-server config (backward compat)
LEGACY_CONFIG="${CONFIG_DIR}/config"

# ─── Server config helpers ──────────────────────────────────────────────────

get_server_file() {
  echo "${SERVERS_DIR}/${1}"
}

load_server() {
  local alias="$1"
  if [ -n "$alias" ] && [ -f "$(get_server_file "$alias")" ]; then
    MDNEST_URL=$(grep '^url=' "$(get_server_file "$alias")" 2>/dev/null | cut -d= -f2-)
    MDNEST_TOKEN=$(grep '^token=' "$(get_server_file "$alias")" 2>/dev/null | cut -d= -f2-)
    CURRENT_ALIAS="$alias"
    return 0
  fi
  return 1
}

load_default() {
  if [ -f "$DEFAULT_FILE" ]; then
    local def
    def=$(cat "$DEFAULT_FILE")
    if load_server "$def"; then return 0; fi
  fi
  if [ -d "$SERVERS_DIR" ]; then
    local first
    first=$(ls "$SERVERS_DIR" 2>/dev/null | head -1)
    if [ -n "$first" ] && load_server "$first"; then return 0; fi
  fi
  if [ -f "$LEGACY_CONFIG" ]; then
    MDNEST_URL=$(grep '^url=' "$LEGACY_CONFIG" 2>/dev/null | cut -d= -f2-)
    MDNEST_TOKEN=$(grep '^token=' "$LEGACY_CONFIG" 2>/dev/null | cut -d= -f2-)
    CURRENT_ALIAS="default"
    return 0
  fi
  return 1
}

require_server() {
  if [ -z "$MDNEST_URL" ] || [ -z "$MDNEST_TOKEN" ]; then
    echo "Not logged in. Run: mdnest login @alias <url> <token>" >&2
    exit 1
  fi
}

# ─── Path parser ────────────────────────────────────────────────────────────
# Parses: @alias/namespace/path/to/file.md
# Or:     namespace/path/to/file.md (uses default server)
# Or:     @alias (just server)
# Or:     @alias/namespace (server + namespace)

parse_path() {
  local input="$1"
  PARSED_ALIAS=""
  PARSED_NS=""
  PARSED_PATH=""

  if [[ "$input" == @* ]]; then
    local rest="${input#@}"
    PARSED_ALIAS="${rest%%/*}"
    if [[ "$rest" == */* ]]; then
      rest="${rest#*/}"
    else
      rest=""
    fi
    input="$rest"
  fi

  if [ -n "$PARSED_ALIAS" ]; then
    if ! load_server "$PARSED_ALIAS"; then
      echo "Unknown server: @${PARSED_ALIAS}. Run 'mdnest servers' to see configured servers." >&2
      exit 1
    fi
  elif [ -z "$MDNEST_URL" ]; then
    if ! load_default; then
      echo "Not logged in. Run: mdnest login @alias <url> <token>" >&2
      exit 1
    fi
  fi

  if [ -n "$input" ]; then
    PARSED_NS="${input%%/*}"
    if [[ "$input" == */* ]]; then
      PARSED_PATH="${input#*/}"
    fi
  fi
}

# ─── API helpers ────────────────────────────────────────────────────────────

api() {
  local method="$1" path="$2" body="$3"
  local args=(-s -w "\n%{http_code}" -H "Authorization: Bearer $MDNEST_TOKEN")
  [ -n "$body" ] && args+=(-d "$body")
  local response
  response=$(curl "${args[@]}" -X "$method" "${MDNEST_URL}/api${path}")
  local http_code="${response##*$'\n'}"
  local resp_body="${response%$'\n'*}"

  if [ "$http_code" -ge 400 ] 2>/dev/null; then
    echo "Error ($http_code): $resp_body" >&2
    return 1
  fi
  echo "$resp_body"
}

urlencode() {
  python3 -c "import urllib.parse, sys; print(urllib.parse.quote(sys.argv[1]))" "$1"
}

# ─── Commands ───────────────────────────────────────────────────────────────

cmd_login() {
  local alias="" url="" tok=""

  if [[ "$1" == @* ]]; then
    alias="${1#@}"
    url="$2"
    tok="$3"
  else
    url="$1"
    tok="$2"
    alias="default"
  fi

  if [ -z "$url" ] || [ -z "$tok" ]; then
    cat <<'USAGE'
Usage:
  mdnest login @alias <url> <token>    Multi-server (you choose the alias name)
  mdnest login <url> <token>           Single server (alias = "default")

The @alias is any name you choose (e.g. @work, @home, @staging).
Login creates or overwrites the alias. To rename: logout + login with new name.

Examples:
  mdnest login @work https://work-server:3236 mdnest_abc123
  mdnest login @personal https://home:3236 mdnest_def456
  mdnest login https://myserver:3236 mdnest_abc123
USAGE
    exit 1
  fi

  url="${url%/}"
  mkdir -p "$SERVERS_DIR"

  # Warn if overwriting a different server without alias
  if [ "$alias" = "default" ] && [ -f "$(get_server_file "default")" ]; then
    local existing_url
    existing_url=$(grep '^url=' "$(get_server_file "default")" 2>/dev/null | cut -d= -f2-)
    if [ -n "$existing_url" ] && [ "$existing_url" != "$url" ]; then
      echo "Warning: replacing existing default server ($existing_url)"
      echo "  To keep both servers, use aliases:"
      echo "    mdnest login @name1 $existing_url <token>"
      echo "    mdnest login @name2 $url <token>"
      echo ""
      read -p "Continue and replace default? (y/N): " confirm
      if [ "$confirm" != "y" ] && [ "$confirm" != "Y" ]; then
        echo "Cancelled. Use: mdnest login @alias $url $tok"
        exit 0
      fi
    fi
  fi

  cat > "$(get_server_file "$alias")" <<EOF
url=${url}
token=${tok}
EOF
  chmod 600 "$(get_server_file "$alias")"

  if [ "$alias" = "default" ] || [ ! -f "$DEFAULT_FILE" ]; then
    echo "$alias" > "$DEFAULT_FILE"
  fi

  if [ -f "$LEGACY_CONFIG" ] && [ "$alias" = "default" ]; then
    rm -f "$LEGACY_CONFIG"
  fi

  if MDNEST_URL="$url" MDNEST_TOKEN="$tok" api GET "/namespaces" > /dev/null 2>&1; then
    echo "Logged in to @${alias} (${url})"
    SERVER_VER=$(curl -s "${url}/api/config" 2>/dev/null | grep -o '"version":"[^"]*"' | cut -d'"' -f4)
    if [ -n "$SERVER_VER" ]; then
      CLI_MAJOR="${MDNEST_CLI_VERSION%%.*}"
      SRV_MAJOR="${SERVER_VER%%.*}"
      if [ "$CLI_MAJOR" != "$SRV_MAJOR" ]; then
        echo "Warning: CLI v${MDNEST_CLI_VERSION} may not be compatible with server v${SERVER_VER}"
      fi
    fi
  else
    echo "Warning: could not reach $url — credentials saved, will retry on next command"
  fi
}

cmd_logout() {
  local alias="${1#@}"
  if [ -z "$alias" ]; then
    rm -rf "$SERVERS_DIR" "$DEFAULT_FILE" "$LEGACY_CONFIG"
    echo "Logged out from all servers"
  else
    rm -f "$(get_server_file "$alias")"
    echo "Logged out from @${alias}"
    if [ -f "$DEFAULT_FILE" ] && [ "$(cat "$DEFAULT_FILE")" = "$alias" ]; then
      rm -f "$DEFAULT_FILE"
      local next
      next=$(ls "$SERVERS_DIR" 2>/dev/null | head -1)
      if [ -n "$next" ]; then
        echo "$next" > "$DEFAULT_FILE"
        echo "Default switched to @${next}"
      fi
    fi
  fi
}

cmd_servers() {
  local verbose=false
  [ "$1" = "-v" ] || [ "$1" = "--verbose" ] && verbose=true

  local def=""
  [ -f "$DEFAULT_FILE" ] && def=$(cat "$DEFAULT_FILE")

  if [ -d "$SERVERS_DIR" ] && [ -n "$(ls "$SERVERS_DIR" 2>/dev/null)" ]; then
    printf "  %-12s  %-35s  %-12s  %s\n" "ALIAS" "URL" "VERSION" "DEFAULT"
    printf "  %-12s  %-35s  %-12s  %s\n" "────────────" "───────────────────────────────────" "────────────" "───────"
    for f in "$SERVERS_DIR"/*; do
      local name=$(basename "$f")
      local url=$(grep '^url=' "$f" 2>/dev/null | cut -d= -f2-)
      local marker=""
      [ "$name" = "$def" ] && marker="*"
      local ver=""
      ver=$(curl -s --max-time 3 "${url}/api/config" 2>/dev/null | grep -o '"version":"[^"]*"' | cut -d'"' -f4)
      [ -n "$ver" ] || ver="unreachable"
      printf "  %-12s  %-35s  %-12s  %s\n" "@${name}" "$url" "$ver" "$marker"

      # Verbose: list namespaces for this server
      if $verbose && [ "$ver" != "unreachable" ]; then
        local tok=$(grep '^token=' "$f" 2>/dev/null | cut -d= -f2-)
        local ns_json
        ns_json=$(curl -s --max-time 3 -H "Authorization: Bearer $tok" "${url}/api/namespaces" 2>/dev/null)
        if [ -n "$ns_json" ] && [ "$ns_json" != "[]" ]; then
          local namespaces
          namespaces=$(echo "$ns_json" | python3 -c "import sys,json; [print('    → @${name}/' + ns) for ns in json.load(sys.stdin)]" 2>/dev/null) || true
          if [ -n "$namespaces" ]; then
            echo "$namespaces"
          fi
        fi
      fi
    done
  elif [ -f "$LEGACY_CONFIG" ]; then
    local url=$(grep '^url=' "$LEGACY_CONFIG" 2>/dev/null | cut -d= -f2-)
    printf "  %-12s  %-35s  %s\n" "@default" "$url" "(legacy config)"
  else
    echo "No servers configured. Run: mdnest login @alias <url> <token>"
  fi
}

cmd_whoami() {
  echo "mdnest CLI v${MDNEST_CLI_VERSION}"
  echo ""
  cmd_servers "$@"
}

cmd_list() {
  parse_path "$1"
  require_server
  if [ -z "$PARSED_NS" ]; then
    api GET "/namespaces"
  else
    api GET "/tree?ns=$(urlencode "$PARSED_NS")"
  fi
}

cmd_read() {
  parse_path "$1"
  require_server
  [ -z "$PARSED_NS" ] || [ -z "$PARSED_PATH" ] && { echo "Usage: mdnest read @alias/namespace/path.md" >&2; exit 1; }
  api GET "/note?ns=$(urlencode "$PARSED_NS")&path=$(urlencode "$PARSED_PATH")"
}

cmd_write() {
  parse_path "$1"
  require_server
  [ -z "$PARSED_NS" ] || [ -z "$PARSED_PATH" ] && { echo "Usage: mdnest write @alias/namespace/path.md <content|->" >&2; exit 1; }
  local content="$2"
  [ "$content" = "-" ] && content=$(cat)
  [ -z "$content" ] && content=$(cat)
  api PUT "/note?ns=$(urlencode "$PARSED_NS")&path=$(urlencode "$PARSED_PATH")" "$content"
}

cmd_create() {
  parse_path "$1"
  require_server
  [ -z "$PARSED_NS" ] || [ -z "$PARSED_PATH" ] && { echo "Usage: mdnest create @alias/namespace/path.md [content]" >&2; exit 1; }
  api POST "/note?ns=$(urlencode "$PARSED_NS")&path=$(urlencode "$PARSED_PATH")" "${2:-}"
}

cmd_append() {
  parse_path "$1"
  require_server
  [ -z "$PARSED_NS" ] || [ -z "$PARSED_PATH" ] && { echo "Usage: mdnest append @alias/namespace/path.md <content|->" >&2; exit 1; }
  local content="$2"
  [ "$content" = "-" ] && content=$(cat)
  [ -z "$content" ] && content=$(cat)
  api PATCH "/note?ns=$(urlencode "$PARSED_NS")&path=$(urlencode "$PARSED_PATH")&position=bottom" "$content"
}

cmd_prepend() {
  parse_path "$1"
  require_server
  [ -z "$PARSED_NS" ] || [ -z "$PARSED_PATH" ] && { echo "Usage: mdnest prepend @alias/namespace/path.md <content|->" >&2; exit 1; }
  local content="$2"
  [ "$content" = "-" ] && content=$(cat)
  [ -z "$content" ] && content=$(cat)
  api PATCH "/note?ns=$(urlencode "$PARSED_NS")&path=$(urlencode "$PARSED_PATH")&position=top" "$content"
}

cmd_delete() {
  parse_path "$1"
  require_server
  [ -z "$PARSED_NS" ] || [ -z "$PARSED_PATH" ] && { echo "Usage: mdnest delete @alias/namespace/path.md" >&2; exit 1; }
  api DELETE "/note?ns=$(urlencode "$PARSED_NS")&path=$(urlencode "$PARSED_PATH")"
}

cmd_move() {
  parse_path "$1"
  require_server
  local to="$2"
  [ -z "$PARSED_NS" ] || [ -z "$PARSED_PATH" ] || [ -z "$to" ] && { echo "Usage: mdnest move @alias/namespace/old-path new-path" >&2; exit 1; }
  api POST "/move?ns=$(urlencode "$PARSED_NS")&from=$(urlencode "$PARSED_PATH")&to=$(urlencode "$to")"
}

cmd_search() {
  parse_path "$1"
  require_server
  local query="$2"
  [ -z "$PARSED_NS" ] || [ -z "$query" ] && { echo "Usage: mdnest search @alias/namespace \"query\"" >&2; exit 1; }
  api GET "/search?ns=$(urlencode "$PARSED_NS")&q=$(urlencode "$query")"
}

# ─── Legacy compat: mdnest note <subcmd> <ns> <path> ───────────────────────

cmd_note_legacy() {
  local subcmd="${1:-help}"
  shift 2>/dev/null || true
  load_default
  require_server
  case "$subcmd" in
    list)     cmd_list "$1" ;;
    read)     cmd_list "${1}/${2}" 2>/dev/null || api GET "/note?ns=$(urlencode "$1")&path=$(urlencode "$2")" ;;
    write)    local ns="$1" p="$2" c="$3"; [ "$c" = "-" ] && c=$(cat); [ -z "$c" ] && c=$(cat); api PUT "/note?ns=$(urlencode "$ns")&path=$(urlencode "$p")" "$c" ;;
    create)   api POST "/note?ns=$(urlencode "$1")&path=$(urlencode "$2")" "${3:-}" ;;
    append)   local ns="$1" p="$2" c="$3"; [ "$c" = "-" ] && c=$(cat); [ -z "$c" ] && c=$(cat); api PATCH "/note?ns=$(urlencode "$ns")&path=$(urlencode "$p")&position=bottom" "$c" ;;
    prepend)  local ns="$1" p="$2" c="$3"; [ "$c" = "-" ] && c=$(cat); [ -z "$c" ] && c=$(cat); api PATCH "/note?ns=$(urlencode "$ns")&path=$(urlencode "$p")&position=top" "$c" ;;
    delete)   api DELETE "/note?ns=$(urlencode "$1")&path=$(urlencode "$2")" ;;
    move)     api POST "/move?ns=$(urlencode "$1")&from=$(urlencode "$2")&to=$(urlencode "$3")" ;;
    search)   api GET "/search?ns=$(urlencode "$1")&q=$(urlencode "$2")" ;;
    help|--help|-h) cmd_help ;;
    *)        echo "Unknown note command: $subcmd" >&2; exit 1 ;;
  esac
}

# ─── Main dispatch ──────────────────────────────────────────────────────────

cmd_help() {
  cat <<HELP
mdnest CLI v${MDNEST_CLI_VERSION}

  Privately-hosted markdown notes. Read, write, search from any terminal.

QUICK REFERENCE (for AI agents / LLMs)
  Path format:  @alias/namespace/path/to/file.md
  New file:     mdnest create @alias/namespace/path.md "content"
  Edit file:    mdnest write  @alias/namespace/path.md "content"  (file MUST exist)
  Read file:    mdnest read   @alias/namespace/path.md
  Append:       mdnest append @alias/namespace/path.md "text"
  Search:       mdnest search @alias/namespace "query"
  List:         mdnest list   @alias/namespace

  IMPORTANT: "create" = new file. "write" = overwrite EXISTING file (returns 404 if not found).
  Use "mdnest servers -v" to discover available @aliases and namespaces.

USAGE
  mdnest <command> [@alias/namespace/path]

PATH FORMAT
  @alias/namespace/path/to/file.md

  @alias     Your chosen name for a server (set during login, e.g. @work, @home)
  namespace  A workspace on that server (e.g. engineering, notes)
  path       File path within the namespace

  Example: mdnest read @work/engineering/Architecture/system-overview.md

  The @alias is optional if you only have one server configured.
  Single-server: mdnest read engineering/Architecture/system-overview.md

SERVER MANAGEMENT
  login    @alias <url> <token>   Add or overwrite a server alias (you choose the name)
  logout   [@alias]               Remove a server (omit alias to remove all)
  servers  [-v]                   List servers (add -v to include namespaces)
  whoami   [-v]                   Show CLI version + servers

  Login creates the alias. There is no rename — logout + login with new name.

NOTE OPERATIONS
  create   <path> [content]       Create a NEW file (fails if already exists)
  write    <path> <content|->     Overwrite an EXISTING file (fails 404 if not found)
  read     <path>                 Read a note (outputs markdown to stdout)
  append   <path> <content|->     Append text to end (creates file if not found)
  prepend  <path> <content|->     Prepend text to start (creates file if not found)
  delete   <path>                 Delete a note or folder
  move     <path> <new-path>      Move/rename within the same namespace
  list     [@alias/namespace]     List namespaces, or files in a namespace
  search   <ns-path> "query"      Search note contents

OTHER
  version                         Show CLI version
  note <subcommand> ...           Legacy command format (still works)
  docs                            Print full CLI reference

EXAMPLES
  # Setup
  mdnest login @work https://work.company.com:3236 mdnest_abc123
  mdnest servers -v                                          # discover aliases + namespaces

  # Create a new file (use "create", NOT "write")
  mdnest create @work/engineering/notes/meeting.md "# Meeting Notes"

  # Update an existing file (use "write")
  mdnest write @work/engineering/notes/meeting.md "# Updated content"

  # Read
  mdnest read @work/engineering/Architecture/system-overview.md

  # Append (creates the file if it doesn't exist)
  echo "- action item" | mdnest append @work/engineering/log.md -

  # Search
  mdnest search @work/engineering "database schema"

  # Single-server shorthand (no @alias needed)
  mdnest list
  mdnest read engineering/docs/api.md
HELP
}

CMD="${1:-help}"
shift 2>/dev/null || true

case "$CMD" in
  login)    cmd_login "$@" ;;
  logout)   cmd_logout "$@" ;;
  servers)  cmd_servers "$@" ;;
  whoami)   cmd_whoami "$@" ;;
  list)     load_default; cmd_list "$@" ;;
  read)     load_default; cmd_read "$@" ;;
  write)    load_default; cmd_write "$@" ;;
  create)   load_default; cmd_create "$@" ;;
  append)   load_default; cmd_append "$@" ;;
  prepend)  load_default; cmd_prepend "$@" ;;
  delete)   load_default; cmd_delete "$@" ;;
  move)     load_default; cmd_move "$@" ;;
  search)   load_default; cmd_search "$@" ;;
  note)     cmd_note_legacy "$@" ;;
  version|--version|-v) echo "mdnest CLI v${MDNEST_CLI_VERSION}" ;;
  docs)
    REAL_PATH="$(readlink -f "$0" 2>/dev/null || python3 -c "import os,sys; print(os.path.realpath(sys.argv[1]))" "$0")"
    DOCS_DIR="$(dirname "$REAL_PATH")/docs"
    [ -f "$DOCS_DIR/cli.md" ] && cat "$DOCS_DIR/cli.md" || echo "Docs not found at $DOCS_DIR/cli.md"
    ;;
  help|--help|-h) cmd_help ;;
  *)
    echo "Unknown command: $CMD"
    echo "Run 'mdnest help' for usage"
    exit 1
    ;;
esac
