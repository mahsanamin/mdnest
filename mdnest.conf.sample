# mdnest configuration
# Copy this file to mdnest.conf and edit to match your setup.
# Run ./mdnest-server rebuild to generate docker-compose.yml and start.

# Auth — change these before first run
MDNEST_USER=admin
MDNEST_PASSWORD=changeme
MDNEST_JWT_SECRET=changeme

# Server alias (used in CLI paths, e.g. @work/namespace/path)
# SERVER_ALIAS=work

# Frontend origin (for CORS)
FRONTEND_ORIGIN=http://localhost:3236

# Ports
BACKEND_PORT=8286
FRONTEND_PORT=3236
# Bind address: 127.0.0.1 = localhost only (default)
# Only set to 0.0.0.0 if you understand the security implications.
# BIND_ADDRESS=127.0.0.1

# Git sync (optional — auto-enabled when keys are in git-sync/keys/)
# Sync is off by default. Your notes stay local unless you set it up.
GIT_AUTHOR_NAME=Your Name
GIT_AUTHOR_EMAIL=you@example.com
# GIT_SYNC_INTERVAL=600          # Seconds between sync cycles (default 10 minutes)

# Search tuning (optional — defaults work for most setups)
# Increase these if you have a large repository (5,000+ notes).
# SEARCH_MAX_RESULTS=30          # Max results per query
# SEARCH_MAX_FILE_SIZE=1048576   # Skip files larger than this (bytes, default 1MB)
# SEARCH_WORKERS=8               # Parallel file readers
# SEARCH_CACHE_TTL=30            # File list cache lifetime (seconds)

# Auth mode: "single" (default) or "multi"
# Single mode: one user, file-based auth (current behavior, no database needed)
# Multi mode: multiple users with roles & permissions, requires PostgreSQL
# AUTH_MODE=single

# PostgreSQL (required only when AUTH_MODE=multi)
# When multi mode is enabled, setup.sh auto-adds a Postgres container to docker-compose.yml.
# If you prefer an external Postgres, set POSTGRES_HOST to its address.
# POSTGRES_HOST=postgres
# POSTGRES_PORT=5432
# POSTGRES_DB=mdnest
# POSTGRES_USER=mdnest
# POSTGRES_PASSWORD=changeme

# SSH key for git pull (optional)
# Path to an SSH private key on the host. Used by the sync button to pull
# from git remotes. Must be unencrypted (no passphrase).
# If your key has a passphrase, generate a dedicated deploy key:
#   ssh-keygen -t ed25519 -f ~/.ssh/mdnest-deploy -N ""
# Then add the .pub key to your GitHub repo's deploy keys.
# SSH_KEY_PATH=/home/you/.ssh/mdnest-deploy

# Live collaboration (optional, requires AUTH_MODE=multi)
# Enables real-time cursor presence and conflict detection via WebSocket.
# Also required for the inline comments feature (/api/comments).
# ENABLE_LIVE_COLLAB=false

# ==========================================================================
# Federated identity via Firebase (optional, requires AUTH_MODE=multi)
# ==========================================================================
# Turn identity into a shared service across multiple mdnest servers. Users
# sign in with Google; TOTP enrolls ONCE in Firestore and works on every
# server that points at the same Firebase project. Each server still decides
# which emails are authorized and at what role.
#
# Step-by-step setup (create project, download keys, configure OAuth):
#     docs/firebase-setup.md
#
# Quick reference:
#   1. Create a Firebase project at https://console.firebase.google.com
#   2. Enable Google sign-in (Authentication → Sign-in method).
#   3. Enable Firestore in production mode.
#   4. Download a service account JSON (Project settings → Service accounts).
#   5. Copy the web SDK config JSON (Project settings → Your apps → Web).
#   6. Fill in the four fields below.
#   7. Add your email to ADMIN_EMAILS so you get admin role on first sign-in.
#
# USER_PROVIDER=firebase
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_SERVICE_ACCOUNT=/home/you/mdnest/firebase-service-account.json
# FIREBASE_WEB_CONFIG=/home/you/mdnest/firebase-web-config.json
#
# Emails promoted to admin on every startup (comma-separated, case-insensitive).
# Removals are NOT auto-demoted — demote explicitly via the admin UI.
# ADMIN_EMAILS=you@example.com,teammate@example.com

# ==========================================================================
# Corporate SSO via generic OIDC (optional, requires AUTH_MODE=multi)
# ==========================================================================
# Alternative to the Firebase block above. Users sign in through your
# corporate IdP (Google Workspace, Okta, Microsoft Entra, Keycloak, Auth0 —
# anything that speaks OIDC discovery). Email is the primary identity key —
# the user must ALREADY exist in mdnest's users table (invited by an admin).
# No auto-provisioning. The IdP owns MFA, so local 2FA is skipped entirely.
#
# Step-by-step setup (create OAuth client, register redirect URI, fill in
# these values): docs/sso-setup.md
#
# USER_PROVIDER=sso
# SSO_ISSUER_URL=https://accounts.google.com        # Google's OIDC issuer
# SSO_CLIENT_ID=<from-devops>
# SSO_CLIENT_SECRET=<from-devops>
#
# Optional — restrict sign-in to specific corporate domains:
# SSO_ALLOWED_DOMAINS=wego.com
#
# Optional — override the button label shown on the sign-in page:
# SSO_PROVIDER_LABEL=Google
#
# Optional — only set if your redirect URI isn't FRONTEND_ORIGIN/api/auth/sso/callback:
# SSO_REDIRECT_URL=https://notes.example.com/api/auth/sso/callback

# HTTPS with Caddy (optional)
# Set CADDY_DOMAIN to enable automatic HTTPS via Let's Encrypt.
# Caddy runs as a container, terminates TLS, and proxies to the frontend.
# Ports 80 and 443 are exposed; backend/frontend ports become internal only.
# The domain must have a DNS A record pointing to this server's public IP.
# CADDY_DOMAIN=notes.example.com

# Namespace mounts
# Each line maps a namespace name to a host directory.
# Format: MOUNT_<name>=<host_path>
# These directories will be mounted into the container and appear as namespaces.
# Example:
# MOUNT_personal=/home/you/notes/personal
# MOUNT_work=/home/you/notes/work
