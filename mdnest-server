#!/bin/bash
set -e

# Change to the directory where this script lives
cd "$(dirname "$0")"

# Auto-detect if git-sync should be enabled:
# keys exist in git-sync/keys/ → include --profile sync
SYNC_PROFILE=""
if [ -d "git-sync/keys" ]; then
  KEY_COUNT=$(find git-sync/keys -maxdepth 1 -type f ! -name "*.pub" ! -name ".gitkeep" 2>/dev/null | wc -l | tr -d ' ')
  if [ "$KEY_COUNT" -gt 0 ]; then
    SYNC_PROFILE="--profile sync"
  fi
fi

compose() {
  docker compose $SYNC_PROFILE "$@"
}

CMD="${1:-help}"
shift 2>/dev/null || true

case "$CMD" in
  setup)
    ./setup.sh
    ;;
  start)
    compose up -d "$@"
    [ -n "$SYNC_PROFILE" ] && echo "git-sync: enabled" || echo "git-sync: disabled (no keys in git-sync/keys/)"
    echo "mdnest is running at http://localhost:$(grep FRONTEND_PORT mdnest.conf 2>/dev/null | head -1 | cut -d= -f2 | tr -d ' ' || echo 3236)"
    ;;
  stop)
    compose down "$@"
    ;;
  restart)
    compose down
    compose up -d "$@"
    [ -n "$SYNC_PROFILE" ] && echo "git-sync: enabled" || echo "git-sync: disabled (no keys in git-sync/keys/)"
    echo "mdnest restarted"
    ;;
  rebuild)
    ./setup.sh
    if [ "$1" = "--full" ]; then
      shift
      echo "Full rebuild: recreating all containers..."
      compose up --build --force-recreate -d "$@"
    else
      compose up --build -d "$@"
      # Force-recreate git-sync only — it uses volume mounts (not built images)
      # so `up --build` won't detect changes to sync.sh or keys
      if [ -n "$SYNC_PROFILE" ]; then
        compose up --force-recreate --no-deps -d git-sync
      fi
    fi
    [ -n "$SYNC_PROFILE" ] && echo "git-sync: enabled" || echo "git-sync: disabled (no keys in git-sync/keys/)"
    echo "mdnest rebuilt and running"
    ;;
  logs)
    compose logs "${@:--f --tail 50}"
    ;;
  status)
    compose ps
    ;;
  update)
    git pull
    ./setup.sh
    compose up --build -d
    echo "mdnest updated and running"
    ;;
  migrate)
    # Run database migrations (multi mode only).
    # Useful for existing users upgrading to multi mode.
    if [ ! -f ".env" ]; then
      echo "Error: .env not found. Run './mdnest-server setup' first."
      exit 1
    fi

    AUTH_MODE=$(grep '^AUTH_MODE=' .env 2>/dev/null | cut -d= -f2)
    if [ "$AUTH_MODE" != "multi" ]; then
      echo "Error: AUTH_MODE is not 'multi' in your configuration."
      echo ""
      echo "To enable multi-user mode:"
      echo "  1. Edit mdnest.conf and set:"
      echo "       AUTH_MODE=multi"
      echo "       POSTGRES_PASSWORD=your_secure_password"
      echo "  2. Run: ./mdnest-server setup"
      echo "  3. Run: ./mdnest-server migrate"
      echo "  4. Run: ./mdnest-server rebuild"
      exit 1
    fi

    echo "Starting postgres..."
    compose up -d postgres
    echo "Running database migrations..."
    compose run --rm backend ./mdnest -migrate
    echo "Migrations complete."
    ;;
  dev-setup)
    echo "Setting up development environment..."
    git config core.hooksPath .githooks
    echo "Git hooks configured (.githooks/pre-push)"
    echo ""
    echo "Pre-push hook verifies:"
    echo "  - Frontend & backend compile"
    echo "  - No high-severity vulnerabilities (npm audit + govulncheck)"
    echo "  - Lock files in sync with package.json"
    echo "  - Version strings consistent across backend, frontend, CLI"
    ;;
  install-cli)
    DEST="/usr/local/bin/mdnest"
    if [ -w "$(dirname "$DEST")" ]; then
      ln -sf "$(pwd)/mdnest" "$DEST"
    else
      sudo ln -sf "$(pwd)/mdnest" "$DEST"
    fi
    echo "Installed: mdnest → $DEST"
    echo "Run 'mdnest login <url> <token>' to get started"
    ;;
  add-namespace)
    echo "=== Add namespace to mdnest ==="
    echo ""

    # 1. Get namespace name
    if [ -n "$1" ]; then
      NS_NAME="$1"; shift
    else
      read -p "Namespace name (e.g. work, personal, docs): " NS_NAME
    fi
    if [ -z "$NS_NAME" ]; then
      echo "Error: namespace name is required"
      exit 1
    fi
    # Sanitize — alphanumeric, hyphens, underscores only
    if ! echo "$NS_NAME" | grep -qE '^[a-zA-Z0-9_-]+$'; then
      echo "Error: namespace name must be alphanumeric (hyphens and underscores OK)"
      exit 1
    fi

    # Check if already exists
    if grep -q "^MOUNT_${NS_NAME}=" mdnest.conf 2>/dev/null; then
      echo "Error: MOUNT_${NS_NAME} already exists in mdnest.conf"
      exit 1
    fi

    # 2. Get host path
    if [ -n "$1" ]; then
      NS_PATH="$1"; shift
    else
      DEFAULT_PATH="$HOME/notes/${NS_NAME}"
      read -p "Host directory path [$DEFAULT_PATH]: " NS_PATH
      NS_PATH="${NS_PATH:-$DEFAULT_PATH}"
    fi

    # Create directory
    if [ ! -d "$NS_PATH" ]; then
      mkdir -p "$NS_PATH"
      echo "Created directory: $NS_PATH"
    fi

    # 3. Add to mdnest.conf
    echo "MOUNT_${NS_NAME}=${NS_PATH}" >> mdnest.conf
    echo "Added MOUNT_${NS_NAME}=${NS_PATH} to mdnest.conf"

    # 4. Ask about git sync
    echo ""
    read -p "Set up git sync for this namespace? (y/N): " SETUP_GIT
    if [ "$SETUP_GIT" = "y" ] || [ "$SETUP_GIT" = "Y" ]; then

      # Initialize git repo if needed
      if [ ! -d "$NS_PATH/.git" ]; then
        cd "$NS_PATH"
        git init
        git config user.name "${GIT_AUTHOR_NAME:-mdnest}"
        git config user.email "${GIT_AUTHOR_EMAIL:-mdnest@localhost}"
        git add -A 2>/dev/null
        git commit -m "Initial commit" --allow-empty 2>/dev/null
        cd - >/dev/null
        echo "Initialized git repo in $NS_PATH"
      fi

      # Generate deploy key
      KEY_PATH="git-sync/keys/${NS_NAME}"
      if [ -f "$KEY_PATH" ]; then
        echo "Deploy key already exists: $KEY_PATH"
      else
        mkdir -p git-sync/keys
        ssh-keygen -t ed25519 -f "$KEY_PATH" -N "" -C "mdnest-${NS_NAME}"
        echo ""
        echo "Deploy key generated: $KEY_PATH"
      fi

      echo ""
      echo "============================================================"
      echo "  PUBLIC KEY — add this as a Deploy Key on your GitHub repo"
      echo "  (Settings → Deploy Keys → Add → check 'Allow write access')"
      echo "============================================================"
      echo ""
      cat "${KEY_PATH}.pub"
      echo ""
      echo "============================================================"
      echo ""

      # Ask for remote URL
      read -p "GitHub SSH remote URL (e.g. git@github.com:user/repo.git): " REMOTE_URL
      if [ -n "$REMOTE_URL" ]; then
        cd "$NS_PATH"
        git remote remove origin 2>/dev/null
        git remote add origin "$REMOTE_URL"
        cd - >/dev/null
        echo "Set remote: $REMOTE_URL"
      fi

      echo ""
      echo "Git sync setup complete for '${NS_NAME}'"
    fi

    echo ""
    echo "=== Next steps ==="
    echo "  1. If git sync: add the public key to your GitHub repo as a Deploy Key (with write access)"
    echo "  2. Run: ./mdnest-server rebuild"
    echo "  3. The namespace will appear in the sidebar"
    ;;
  git-check)
    echo "=== mdnest git-sync diagnostics ==="
    echo ""

    # Check keys
    if [ -d "git-sync/keys" ]; then
      KEY_FILES=$(find git-sync/keys -maxdepth 1 -type f ! -name "*.pub" ! -name ".gitkeep" 2>/dev/null)
      if [ -z "$KEY_FILES" ]; then
        echo "KEYS: none found in git-sync/keys/"
        echo "  → Git sync is disabled. Add deploy keys to enable."
        exit 0
      fi
      echo "KEYS:"
      for key in $KEY_FILES; do
        name=$(basename "$key")
        pub="${key}.pub"
        echo "  $name"
        if [ -f "$pub" ]; then
          echo "    Public key: $(cat "$pub")"
        else
          echo "    WARNING: no .pub file — run: ssh-keygen -y -f git-sync/keys/$name > git-sync/keys/${name}.pub"
        fi
      done
    else
      echo "KEYS: git-sync/keys/ directory not found"
      echo "  → Run: mkdir -p git-sync/keys && ssh-keygen -t ed25519 -f git-sync/keys/default -N ''"
      exit 0
    fi

    echo ""

    # Check each namespace repo
    # Find MOUNT_ entries from mdnest.conf
    if [ ! -f "mdnest.conf" ]; then
      echo "ERROR: mdnest.conf not found"
      exit 1
    fi

    echo "NAMESPACES:"
    grep '^MOUNT_' mdnest.conf | while IFS='=' read -r key path; do
      name="${key#MOUNT_}"
      path=$(echo "$path" | tr -d ' ')
      echo ""
      echo "  $name → $path"

      if [ ! -d "$path" ]; then
        echo "    WARNING: directory does not exist"
        continue
      fi

      if [ ! -d "$path/.git" ]; then
        echo "    No git repo (sync skipped — this is fine for local-only namespaces)"
        continue
      fi

      cd "$path"
      REMOTE_URL=$(git remote get-url origin 2>/dev/null || echo "")
      BRANCH=$(git branch --show-current 2>/dev/null || echo "unknown")

      if [ -z "$REMOTE_URL" ]; then
        echo "    Git repo but no remote — commits stay local"
        continue
      fi

      echo "    Remote: $REMOTE_URL"
      echo "    Branch: $BRANCH"

      # Check for SSH host alias
      REMOTE_HOST=$(echo "$REMOTE_URL" | sed -n 's/^[^@]*@\([^:]*\):.*/\1/p')
      if [ -n "$REMOTE_HOST" ]; then
        case "$REMOTE_HOST" in
          github.com|gitlab.com|bitbucket.org)
            echo "    Host: $REMOTE_HOST (OK)"
            ;;
          *)
            echo "    WARNING: SSH host alias '$REMOTE_HOST' won't work inside Docker!"
            REPO_PATH=$(echo "$REMOTE_URL" | sed 's/^[^:]*://')
            echo "    Fix: git remote set-url origin git@github.com:${REPO_PATH}"
            echo "    (git-sync will auto-fix this on next cycle)"
            ;;
        esac
      fi

      # Check key mapping
      if [ -f "git-sync/keys/$name" ]; then
        echo "    Key: git-sync/keys/$name (per-namespace)"
      elif [ -f "git-sync/keys/default" ]; then
        echo "    Key: git-sync/keys/default (shared)"
      else
        echo "    WARNING: no matching key — push/pull will fail"
        echo "    Fix: cp your-deploy-key git-sync/keys/$name"
      fi
      cd - >/dev/null
    done

    echo ""
    echo "=== Testing SSH connectivity ==="
    if command -v ssh >/dev/null 2>&1; then
      for key in $KEY_FILES; do
        name=$(basename "$key")
        echo -n "  $name → github.com: "
        RESULT=$(ssh -T git@github.com -i "$key" -o StrictHostKeyChecking=accept-new -o ConnectTimeout=5 2>&1 || true)
        if echo "$RESULT" | grep -q "successfully authenticated"; then
          USER=$(echo "$RESULT" | grep -o 'Hi [^!]*' | sed 's/Hi //')
          echo "OK (authenticated as $USER)"
        else
          echo "FAILED"
          echo "    $RESULT"
          echo "    → Add the public key as a deploy key (with write access) on your GitHub repo"
        fi
      done
    else
      echo "  ssh not available on host — test from inside container:"
      echo "  docker compose exec git-sync sh -c 'ssh -T git@github.com -i /keys/<keyname>'"
    fi
    echo ""
    ;;
  help|--help|-h)
    cat <<'HELP'
mdnest-server — manage your mdnest instance

Usage: mdnest-server <command>

Commands:
  setup       Generate docker-compose.yml and .env from mdnest.conf
  start       Start all services (includes git-sync if keys are configured)
  stop        Stop all services
  restart     Stop and start all services
  add-namespace  Add a namespace: create dir, deploy key, git remote, update config
  rebuild     Re-run setup, rebuild changed images, and start
  rebuild --full  Force recreate ALL containers (use after major updates)
  logs        View logs (all services, or specify: backend, frontend, git-sync, postgres)
  git-check   Diagnose git-sync: keys, remotes, SSH connectivity
  status      Show running containers
  update      Pull latest code, rebuild, and start
  migrate     Run database migrations (multi-user mode only)
  install-cli Install the mdnest CLI system-wide (/usr/local/bin)
  dev-setup   Configure git hooks (pre-push: build, audit, version check)

Git sync starts automatically when deploy keys are found in git-sync/keys/.
No keys = no sync. Your notes stay local unless you set it up.

Multi-user mode requires AUTH_MODE=multi in mdnest.conf and a PostgreSQL database.
When AUTH_MODE=multi, setup automatically adds a Postgres container.

Examples:
  mdnest-server setup           # first-time setup
  mdnest-server start           # start everything
  mdnest-server rebuild         # after editing mdnest.conf (smart, fast)
  mdnest-server rebuild --full  # force recreate all containers
  mdnest-server add-namespace    # interactive: add namespace + git sync
  mdnest-server git-check       # diagnose git-sync keys & remotes
  mdnest-server logs             # all service logs
  mdnest-server logs backend     # backend only
  mdnest-server logs git-sync    # git sync only

Upgrading to multi-user mode:
  1. Edit mdnest.conf:  AUTH_MODE=multi, POSTGRES_PASSWORD=<secure>
  2. mdnest-server setup        # regenerates docker-compose with postgres
  3. mdnest-server migrate      # creates database tables
  4. mdnest-server rebuild      # rebuilds and starts everything
HELP
    ;;
  *)
    echo "Unknown command: $CMD"
    echo "Run 'mdnest-server help' for usage"
    exit 1
    ;;
esac
